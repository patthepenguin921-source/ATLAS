# =====================================================================
# ATLAS — Academic Operating System · Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =====================================================================

# ---------- Supabase (shared by backend + frontend) ----------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Publishable / anon key (safe for the browser)
SUPABASE_ANON_KEY=sb_publishable_xxx
# Service role key (BACKEND ONLY — full DB access, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# No JWT secret needed — the backend verifies tokens by calling Supabase's
# own /auth/v1/user endpoint, so it works with either signing scheme.

# ---------- Reasoning engine (pluggable provider) ----------
# groq (free tier, default) | anthropic (paid, higher quality)
ATLAS_LLM_PROVIDER=groq

# Groq — https://console.groq.com/keys (free)
GROQ_API_KEY=gsk_xxx
ATLAS_GROQ_MODEL=llama-3.3-70b-versatile
ATLAS_GROQ_FAST_MODEL=llama-3.1-8b-instant

# Anthropic / Claude — optional upgrade, only used if ATLAS_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ATLAS_CLAUDE_MODEL=claude-opus-4-8
ATLAS_CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# ---------- Embeddings (semantic memory) ----------
# Provider: voyage | openai | local
# - voyage  : Anthropic-recommended, needs VOYAGE_API_KEY
# - openai  : needs OPENAI_API_KEY
# - local   : deterministic fallback (NO semantic quality) so the app runs keyless
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=voyage-3
EMBEDDINGS_DIM=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ---------- Storage (Cloudflare R2 — S3-compatible, free tier) ----------
# Dashboard → R2 → create a bucket, then Manage API tokens → create a token
# scoped to that bucket with Object Read & Write permissions.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket name (create it in the R2 dashboard first)
ATLAS_STORAGE_BUCKET=atlas-documents

# ---------- Backend server ----------
ATLAS_ENV=development
# Encrypts stored integration credentials (e.g. PowerSchool portal login).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ATLAS_SECRET_KEY=
# Comma-separated allow-list of frontend origins. Defaults to "*" (any origin)
# because Atlas uses Bearer-token auth, not cookies — so cross-origin document
# uploads work out of the box. Set an explicit list to lock this down.
ATLAS_CORS_ORIGINS=*

# ---------- Frontend (Next.js — must be prefixed NEXT_PUBLIC_) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---------- Google Drive Picker (Documents → "Import from Drive") ----------
# Create an OAuth 2.0 Client ID (Web) + API key in Google Cloud Console, enable
# the Google Picker API + Drive API, and authorize your frontend origin.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
