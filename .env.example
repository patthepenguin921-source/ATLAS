# =====================================================================
# ATLAS — Academic Operating System · Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =====================================================================

# ---------- Supabase (shared by backend + frontend) ----------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Publishable / anon key (safe for the browser)
SUPABASE_ANON_KEY=sb_publishable_xxx
# Service role key (BACKEND ONLY — full DB access, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# JWT secret used to verify Supabase-issued access tokens on the backend.
# Found in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------- Anthropic / Claude (reasoning engine) ----------
ANTHROPIC_API_KEY=sk-ant-xxx
# Primary reasoning model
ATLAS_CLAUDE_MODEL=claude-opus-4-8
# Cheaper model for lightweight/high-volume tasks (tagging, summaries)
ATLAS_CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# ---------- Embeddings (semantic memory) ----------
# Provider: voyage | openai | local
# - voyage  : Anthropic-recommended, needs VOYAGE_API_KEY
# - openai  : needs OPENAI_API_KEY
# - local   : deterministic fallback (NO semantic quality) so the app runs keyless
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=voyage-3
EMBEDDINGS_DIM=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ---------- Storage ----------
# Supabase Storage bucket for uploaded documents
ATLAS_STORAGE_BUCKET=atlas-documents

# ---------- Backend server ----------
ATLAS_ENV=development
ATLAS_CORS_ORIGINS=http://localhost:3000

# ---------- Frontend (Next.js — must be prefixed NEXT_PUBLIC_) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
