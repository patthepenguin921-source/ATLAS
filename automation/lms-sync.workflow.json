{
  "name": "Atlas · LMS Sync (Schoology)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 7,16 * * *" }
          ]
        }
      },
      "id": "trigger",
      "name": "7am & 4pm (NY)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ATLAS_API }}/api/v1/integrations/schoology/sync",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "request",
      "name": "Sync Schoology",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "credentials": { "httpHeaderAuth": { "id": "atlas-backend", "name": "Atlas Backend" } }
    }
  ],
  "connections": {
    "7am & 4pm (NY)": { "main": [[{ "node": "Sync Schoology", "type": "main", "index": 0 }]] }
  },
  "settings": { "timezone": "America/New_York" },
  "active": true
}
